# cp .env.example .env

DATABASE_URL=postgres://user:password@localhost:5432/hius_dev

# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=
HMAC_KEY=

# Any string identifier for the active key version, e.g. v1-2026-04-21
KEY_ID=

# Optional JSON array of historical keys for decrypt during rotation.
# Warning: quoting JSON in shell/CI is error-prone; prefer loading it from a .env file.
# Example:
# KEYRING_JSON=[{"keyId":"v1-2026-04-21","encryptionKey":"q6urq6urq6urq6urq6urq6urq6urq6urq6urq6urq6s=","hmacKey":"u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7u7s="}]
KEYRING_JSON=

# Set to "true" to enable deterministic encryption (disabled by default)
ENABLE_DETERMINISTIC_ENCRYPTION=false
